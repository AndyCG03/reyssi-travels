<!-- ═══════════════════════════════════════ DESTINOS (filtros + flip cards) ═══════════════════════════════════════ -->
<section id="destinos">
  <div class="container">
    <div class="filtros reveal">
      <div class="filtro-grupo">
        <span class="filtro-label">Continente</span>
        <% continentes.forEach(function(c, i){ %>
          <button class="chip<%= i === 0 ? ' active' : '' %>" data-group="continente" data-value="<%= c[0] %>"><%= c[1] %></button>
        <% }) %>
      </div>
      <div class="filtro-grupo">
        <span class="filtro-label">Experiencia</span>
        <% intereses.forEach(function(t, i){ %>
          <button class="chip<%= i === 0 ? ' active' : '' %>" data-group="interes" data-value="<%= t[0] %>"><%= t[1] %></button>
        <% }) %>
      </div>
    </div>

    <div class="destinos-grid destinos-uniform">
      <% destinos.forEach(function(d){ %>
        <div class="destino-card reveal" tabindex="0" data-continente="<%= d.continente %>" data-interes="<%= d.interes %>">
          <div class="destino-inner">
            <div class="destino-front">
              <% if (d.badge) { %><span class="destino-badge"><%= d.badge %></span><% } %>
              <img src="https://images.unsplash.com/photo-<%= d.img %>?w=700&q=80" alt="<%= d.name %>" loading="lazy" />
              <div class="destino-overlay"><span class="tag"><%= d.region %></span><h3><%= d.name %></h3></div>
            </div>
            <div class="destino-back">
              <span class="tag"><%= d.region %></span>
              <h3><%= d.name %></h3>
              <p><%= d.desc %></p>
              <ul class="destino-meta">
                <li><span>Mejor época</span><strong><%= d.epoca %></strong></li>
                <li><span>Duración</span><strong><%= d.duracion %></strong></li>
              </ul>
              <a href="/contacto" class="destino-cta">Consultar este viaje →</a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
    <p class="destinos-empty">No hay destinos con esos filtros. Probá otra combinación o <a href="/contacto">escribinos</a> — lo armamos igual.</p>
  </div>
</section>

<!-- ═══════════════════════════════════════ MAPA INTERACTIVO ═══════════════════════════════════════ -->
<section id="mapa">
  <div class="container">
    <div class="section-header reveal">
      <span class="tag">Explorá el mundo</span>
      <div class="divider center"></div>
      <h2>Dónde llegamos</h2>
      <p style="color:var(--texto-suave); max-width:560px; margin:0 auto;">Arrastrá, hacé zoom y tocá cada punto para ver el destino.</p>
    </div>
    <div
      id="mapa-mundi"
      class="reveal"
      data-destinos='<%= JSON.stringify(destinos.map(function(d){ return { name:d.name, region:d.region, lat:d.lat, lng:d.lng, epoca:d.epoca, duracion:d.duracion }; })) %>'
      aria-label="Mapa de destinos"
    ></div>
  </div>
</section>

<%- include('partials/cta', { cta_title: 'Tu destino soñado, hecho a tu medida', cta_text: 'Contanos a dónde querés ir (o dejate sorprender) y armamos el viaje perfecto para vos.' }) %>
