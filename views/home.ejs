<%- include('partials/head', { title: 'Reyssi Travels | Viajes de Aventura y Naturaleza', desc: 'Asesoría de viajes de aventura y naturaleza. Diseñamos experiencias a medida: trekking, safaris, expediciones y más.', page: 'inicio' }) %>

<!-- ═══════════════════════════════════════ HERO (scroll-video) ═══════════════════════════════════════ -->
<section id="hero">
  <div class="hero-sticky">
    <!-- El video se carga por JS solo en desktop (data-src); en móvil se ve el poster -->
    <video class="hero-video" muted playsinline preload="none"
           poster="/images/hero-poster.jpg"
           data-src="/videos/hero-web-min.mp4"
           data-src-mobile="/videos/hero-mobile.mp4"></video>
    <div class="hero-content">
      <h1>Viajes que <span class="highlight">transforman</span><br>la manera de ver el mundo</h1>
      <p>Diseñamos experiencias de aventura y naturaleza completamente a medida. Cada ruta, cada detalle, pensado para vos.</p>
      <div class="hero-btns">
        <a href="/contacto" class="btn-primary">
          Planificar mi viaje
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/destinos" class="btn-secondary">
          Ver destinos
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </a>
      </div>
    </div>
    <div class="hero-cue" aria-hidden="true">
      <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M6 9l6 6 6-6"/>
      </svg>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════ CONFIANZA (carrusel marquee) ═══════════════════════════════════════ -->
<%
  const trust = [
    { svg: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>', title: 'Atención 100% personalizada', text: 'Un solo asesor de principio a fin.' },
    { svg: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>', title: 'Soporte 24/7 en viaje', text: 'Disponibles ante cualquier imprevisto.' },
    { svg: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>', title: 'Pagos seguros y en cuotas', text: 'Mercado Pago y financiación flexible.' },
    { svg: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>', title: 'Primera consulta sin cargo', text: 'Sin compromiso ni letra chica.' },
    { svg: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>', title: 'Itinerarios a medida', text: 'Diseñados según tu perfil viajero.' },
    { svg: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/></svg>', title: 'Turismo responsable', text: 'Operadores locales y naturaleza primero.' }
  ];
%>
<section id="confianza">
  <div class="marquee" aria-label="Por qué elegirnos">
    <div class="marquee-track">
      <% for (let dup = 0; dup < 2; dup++) { %>
        <% trust.forEach(function(t){ %>
          <div class="confianza-item"<%= dup === 1 ? ' aria-hidden="true"' : '' %>>
            <div class="ci-icon"><%- t.svg %></div>
            <div><h4><%= t.title %></h4><p><%= t.text %></p></div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════ INTRO / PROPUESTA ═══════════════════════════════════════ -->
<section id="propuesta">
  <div class="container">
    <div class="propuesta-grid">
      <div class="propuesta-text reveal">
        <span class="tag">Por qué elegirnos</span>
        <div class="divider"></div>
        <h2>Una asesoría que conoce cada sendero de memoria</h2>
        <p>En Reyssi Travels no vendemos paquetes genéricos. Escuchamos tus sueños, analizamos tu perfil viajero y construimos una experiencia que se ajusta exactamente a lo que buscás.</p>
        <p>Trabajamos de manera 100% online, con atención personalizada, comunicación directa y respaldo en cada etapa de tu viaje.</p>
        <a href="/nosotros" class="btn-primary" style="margin-top:1.4rem;">
          Conocé más sobre nosotros
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="propuesta-img reveal">
        <img src="https://images.unsplash.com/photo-1551632811-561732d1e306?w=900&q=80" alt="Senderismo en montaña" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════ DESTINOS DESTACADOS ═══════════════════════════════════════ -->
<section id="destinos">
  <div class="container">
    <div class="section-header reveal">
      <span class="tag">Destinos favoritos</span>
      <div class="divider center"></div>
      <h2>Lugares que nos quitan el aliento</h2>
    </div>
    <%
      const destacados = [
        { name: 'Patagonia', region: 'Argentina · Chile', badge: '⭐ Más visitado',
          img: 'https://images.unsplash.com/photo-1469474968028-56623f02e42e?w=900&q=80',
          desc: 'Glaciares, montañas y estepa infinita.',
          epoca: 'Oct – Abr', duracion: '10–16 días', lugares: ['El Chaltén','Perito Moreno','Torres del Paine'] },
        { name: 'Islandia', region: 'Europa del Norte',
          img: 'https://images.unsplash.com/photo-1585409677983-0f6c41ca9c3b?w=600&q=80',
          desc: 'Cascadas, volcanes y auroras boreales.',
          epoca: 'Jun–Ago / auroras Sep–Mar', duracion: '8–12 días', lugares: ['Círculo Dorado','Jökulsárlón','Blue Lagoon'] },
        { name: 'Nepal', region: 'Asia del Sur',
          img: 'https://images.unsplash.com/photo-1516690561799-46d8f74f9abf?w=600&q=80',
          desc: 'El Himalaya en su esplendor.',
          epoca: 'Mar–May / Oct–Nov', duracion: '14–20 días', lugares: ['Everest Base Camp','Annapurna','Katmandú'] }
      ];
    %>
    <div class="destinos-grid destinos-uniform">
      <% destacados.forEach(function(d){ %>
        <div class="destino-card reveal" tabindex="0">
          <div class="destino-inner">
            <div class="destino-front">
              <% if (d.badge) { %><span class="destino-badge"><%= d.badge %></span><% } %>
              <img src="<%= d.img %>" alt="<%= d.name %>" loading="lazy" />
              <div class="destino-overlay"><span class="tag"><%= d.region %></span><h3><%= d.name %></h3></div>
            </div>
            <div class="destino-back">
              <span class="tag"><%= d.region %></span>
              <h3><%= d.name %></h3>
              <p><%= d.desc %></p>
              <p class="destino-spots"><span>Lugares de interés:</span> <%= d.lugares.join(' · ') %></p>
              <ul class="destino-meta">
                <li><span>Mejor época</span><strong><%= d.epoca %></strong></li>
                <li><span>Duración</span><strong><%= d.duracion %></strong></li>
              </ul>
              <a href="/contacto" class="destino-cta">Consultar este viaje →</a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
    <div style="text-align:center; margin-top:2.5rem;">
      <a href="/destinos" class="btn-secondary" style="color:var(--azul-dark); border-color:var(--gris-suave); background:var(--blanco);">
        Ver todos los destinos
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<%- include('partials/cta') %>
<%- include('partials/footer') %>
