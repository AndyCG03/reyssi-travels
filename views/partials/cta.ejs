<!-- Banda CTA reutilizable -->
<section id="cta-band">
  <video class="cta-video" autoplay muted loop playsinline preload="metadata" poster="/images/cta-poster.jpg">
    <source src="/videos/CTA-web.mp4" type="video/mp4">
  </video>
  <div class="cta-overlay"></div>
  <div class="container reveal">
    <h2><%= typeof cta_title !== 'undefined' ? cta_title : 'Tu próxima gran aventura empieza con una conversación' %></h2>
    <p><%= typeof cta_text !== 'undefined' ? cta_text : 'Sin compromiso. Contanos qué soñás y te enviamos una primera propuesta en menos de 24 horas.' %></p>
    <div class="hero-btns">
      <a href="/contacto" class="btn-primary">
        Empezar a planificar
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>
